# Fastlane configuration for Unity tvOS Snake Game
# Adapted from CAWCAW iOS pipeline for tvOS distribution
#
# Key difference from a typical iOS Fastfile: Unity generates the Xcode
# project (not Xcode directly), so build_release archives from the
# Unity-generated .xcodeproj rather than a workspace.

default_platform(:ios)

# tvOS uses the :ios platform in fastlane with platform: "tvos" for match/sigh
platform :ios do
  before_all do
    if ENV['CI']
      setup_ci
    end
  end

  # ============================================
  # Authentication
  # ============================================

  desc "Load App Store Connect API Key"
  private_lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_PRIVATE_KEY"],
      duration: 1200,
      in_house: false
    )
  end

  # ============================================
  # Certificates & Profiles
  # ============================================

  desc "Sync tvOS certificates and provisioning profiles for App Store"
  lane :sync_certificates do
    load_asc_api_key
    match(
      type: "appstore",
      platform: "tvos",
      app_identifier: "dev.birks.snakegame",
      force: ENV['MATCH_FORCE_WRITE'] == 'true',
      readonly: ENV['CI'] && (ENV['MATCH_FORCE_WRITE'] != true && ENV['MATCH_FORCE_WRITE'] != 'true'),
      keychain_name: ENV['CI'] ? 'build.keychain' : 'login.keychain',
      keychain_password: ENV['CI'] ? '' : nil
    )
  end

  desc "Download tvOS certificates for distribution"
  lane :certificates_distribution do
    load_asc_api_key
    match(
      type: "appstore",
      platform: "tvos",
      app_identifier: "dev.birks.snakegame",
      readonly: ENV['CI'] && (ENV['MATCH_FORCE_WRITE'] != true && ENV['MATCH_FORCE_WRITE'] != 'true'),
      keychain_name: ENV['CI'] ? 'build.keychain' : 'login.keychain',
      keychain_password: ENV['CI'] ? '' : nil
    )
  end

  desc "Download tvOS certificates for development"
  lane :certificates_development do
    load_asc_api_key
    match(
      type: "development",
      platform: "tvos",
      app_identifier: "dev.birks.snakegame"
    )
  end

  # ============================================
  # Build
  # ============================================

  desc "Build the tvOS app for release (from Unity-generated Xcode project)"
  lane :build_release do
    sync_certificates

    # Verify certificate installation
    if ENV['CI']
      sh("security find-identity -v -p codesigning build.keychain")
      # Ensure tvOS platform is available (must be done right before xcodebuild)
      sh("xcodebuild -downloadPlatform tvOS 2>&1 || true")
      sh("xcodebuild -showsdks | grep tvos")
    end

    # Timestamp-based build number (same pattern as CAWCAW)
    build_number = Time.now.strftime("%Y%m%d%H%M")

    # The Unity build script outputs an Xcode project to build/tvOS/
    # This lane assumes that project already exists (built by GameCI or local Unity)
    # Use absolute path from project root to avoid working directory issues
    project_root = ENV['GITHUB_WORKSPACE'] || File.expand_path("../", __dir__)
    xcode_project = File.join(project_root, "build/tvOS/Unity-iPhone.xcodeproj")

    unless File.exist?(xcode_project)
      UI.user_error!("Xcode project not found at #{xcode_project}. Run Unity build first!")
    end

    # Update build number in the generated Xcode project
    increment_build_number(
      build_number: build_number,
      xcodeproj: xcode_project
    )

    # Unity generates two targets: Unity-iPhone (app) and UnityFramework (framework).
    # Set signing per-target: manual for the app, automatic for the framework.
    update_code_signing_settings(
      path: xcode_project,
      use_automatic_signing: false,
      team_id: "64U9465SFY",
      bundle_identifier: "dev.birks.snakegame",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore dev.birks.snakegame tvos",
      targets: ["Unity-iPhone"]
    )

    # UnityFramework is an embedded framework — disable code signing entirely
    # (it gets re-signed as part of the app bundle during archive)
    update_code_signing_settings(
      path: xcode_project,
      use_automatic_signing: false,
      code_sign_identity: "",
      targets: ["UnityFramework"]
    )

    build_app(
      project: xcode_project,
      scheme: "Unity-iPhone",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      include_bitcode: false,
      include_symbols: true,
      destination: "generic/platform=tvOS,name=Any tvOS Device",
      sdk: "appletvos",
      xcargs: [
        (ENV['CI'] ? "OTHER_CODE_SIGN_FLAGS='--keychain build.keychain'" : ""),
        "-allowProvisioningUpdates",
        "INFOPLIST_KEY_ITSAppUsesNonExemptEncryption=NO"
      ].reject(&:empty?).join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        provisioningProfiles: {
          "dev.birks.snakegame" => "match AppStore dev.birks.snakegame tvos"
        },
        signingCertificate: "Apple Distribution",
        compileBitcode: false,
        uploadBitcode: false,
        uploadSymbols: true,
        thinning: "<none>"
      }
    )
  end

  # ============================================
  # TestFlight Upload
  # ============================================

  desc "Upload to TestFlight"
  lane :upload_testflight do
    load_asc_api_key

    is_external_release = ENV['GITHUB_REF'] && ENV['GITHUB_REF'].start_with?('refs/tags/v')

    if is_external_release
      # Tagged releases: distribute to external group (triggers beta review)
      upload_to_testflight(
        skip_waiting_for_build_processing: false,
        skip_submission: false,
        distribute_external: true,
        groups: ["Pre-release"],
        changelog: "New version: #{ENV['GITHUB_REF_NAME']}",
        notify_external_testers: true,
        uses_non_exempt_encryption: false,
        beta_app_description: "Snake game for Apple TV — free-flowing snake with flat orange aesthetic",
        beta_app_feedback_email: "david@birks.dev"
      )
    else
      # Internal builds: upload only, NO group distribution, NO beta review.
      # Internal team members (App Store Connect users) automatically see all
      # processed builds in TestFlight without needing group assignment.
      upload_to_testflight(
        skip_waiting_for_build_processing: false,
        skip_submission: true,
        changelog: "Internal build from CI",
        uses_non_exempt_encryption: false,
        beta_app_description: "Snake game for Apple TV — free-flowing snake with flat orange aesthetic",
        beta_app_feedback_email: "david@birks.dev"
      )
    end
  end

  # ============================================
  # Combined Lanes
  # ============================================

  desc "Build and upload to TestFlight"
  lane :beta do
    build_release
    upload_testflight

    if ENV['CI']
      puts "Successfully uploaded build to TestFlight!"
      puts "Check your build at: https://appstoreconnect.apple.com"
    end
  end

  # ============================================
  # Error Handling
  # ============================================

  error do |lane, exception|
    puts "Error in lane #{lane}: #{exception}"
    if ENV['CI']
      puts "Check the GitHub Actions logs for more details"
    end
  end
end
